    <title>Car Seller Registration Page</title>
    <style>
        *{margin:0;padding:0;box-sizing:border-box;}
        .hero-banner{
            width:100%;
            height:700px;
            background-image: url("greencar.jpg");
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            position:relative;
            display:flex;flex-direction:column;justify-content:center;align-items:center;color:white;text-align:center;
        }
        .hero-banner::before{content:'';position:absolute;top:0;left:0;width:100%;height:100%;background-color:rgba(0, 0, 0, 0.466);z-index:1;}
        .hero-title{font-size:60px;font-weight:bold;position:relative;z-index:2;margin-bottom:16px;}
        .hero-desc{font-size:18px;position:relative;z-index:2;max-width:700px;line-height:1.6;}
        h1{color:#89f0a1;font-size: 38px;text-align:center;font-weight:bold;font-family:fantasy;margin:40px 0;text-shadow: 0 4px 12px rgba(0, 0, 0, 0.8);}
        h2{color:#222222;font-size: 28px;text-align:left;font-weight:bold;font-family:system-ui;margin-bottom:30px;}

        .gray-header-bar {
            width: 100%;
            background-color: #eaeaea;
            padding: 30px 0;
            font-size: 26px;
            font-weight: bold;
            color: #333;
            text-align: center;
            margin: 0 auto;
        }

        .stats-section {
            max-width: 1400px;
            margin: 5rem auto 5rem;
            padding: 0 2rem;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 30px;
        }
        .stat-card {
            background: rgba(245, 245, 245, 0.85);
            border-radius: 12px;
            padding: 45px 20px 30px;
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;
            transition: all 0.3s ease;
            cursor: default;
        }
        .stat-card:hover {
            transform: scale(1.05);
            background: rgba(230, 230, 230, 0.95);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
        }
        .stat-icon-circle {
            width: 70px;
            height: 70px;
            background-color: rgba(87, 86, 86, 1);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            position: absolute;
            top: -35px;
            transition: all 0.3s ease;
        }
        .stat-card:hover .stat-icon-circle {
            background-color: rgba(65, 64, 64, 1);
        }
        .stat-icon-circle svg {
            width: 32px;
            height: 32px;
            fill: burlywood;
            transition: all 0.3s ease;
        }
        .stat-card:hover .stat-icon-circle svg {
            fill: rgba(0, 255, 157, 1);
        }
        .stat-number {
            font-size: 3.2rem;
            font-weight: 600;
            color: #333;
            margin: 10px 0 8px;
            transition: all 0.3s ease;
        }
        .stat-card:hover .stat-number {
            color: rgba(87, 86, 86, 1);
        }
        .stat-text {
            font-size: 1.1rem;
            color: #555;
            margin: 0;
            text-transform: capitalize;
        }

        .car-gallery-section {
            max-width: 1200px;
            margin: 60px auto;
            padding: 0 5%;
        }
        .car-gallery {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 25px;
        }
        .car-item {
            position: relative;
            perspective: 1000px;
        }
        .car-item img {
            width: 100%;
            height: 180px;
            object-fit: contain;
            filter: drop-shadow(0 10px 15px rgba(0, 0, 0, 0.25));
            transform: rotateX(5deg);
            transition: all 0.3s ease;
        }
        .car-item:hover img {
            transform: rotateX(0deg) scale(1.08);
            filter: drop-shadow(0 15px 25px rgba(0, 0, 0, 0.35));
        }
        .car-caption {
            text-align: center;
            margin-top: 12px;
            font-size: 16px;
            color: #555;
            font-weight: 500;
        }
        @media (max-width: 768px) {
            .car-gallery {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        /* 全局背景 */
        body {
            position: relative;
        }
        .bg-side-left,
        .bg-side-right {
            position: fixed;
            top: 0;
            width: 12%;
            height: 100%;
            z-index: -99;
            opacity: 0.22;
            filter: blur(6px);
            background-size: cover;
            background-position: center;
        }
        .bg-side-left {
            left: 0;
            background-image: url("background1.png");
        }
        .bg-side-right {
            right: 0;
            background-image: url("background2.png");
        }

        /* ========== 表单核心修复 ========== */
        .contact-form-section {
            max-width: 1400px;
            margin: 80px auto;
            padding: 0 5%;
            position: relative;
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 0 20px rgba(0,0,0,0.05);
            padding: 60px 80px;
        }
        .contact-form-section h2 {
            font-size: 32px;
            margin-bottom: 40px;
            text-align: left;
        }
        .form-three-column {
            display: grid;
            gap: 40px;
            margin-bottom: 30px;
            width: 100%;
        }
        .form-three-column.col2 {
            grid-template-columns: 1fr 1fr;
        }
        .form-three-column.col3 {
            grid-template-columns: 1fr 1fr 1fr;
        }
        .form-full-column {
            width: 100%;
            margin-bottom: 30px;
        }
        .form-item {
            display: flex;
            flex-direction: column;
            gap: 12px;
            width: 100%;
        }
        .form-item-label {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 22px;
            color: #333;
            font-weight: normal;
            white-space: nowrap;
        }
        .form-item input {
            border: none;
            border-bottom: 1px solid #dddddd;
            background: transparent;
            padding: 10px 0;
            font-size: 20px;
            color: #666;
            outline: none;
            width: 100%;
        }
        .verify-row {
            display: flex;
            align-items: center;
            gap: 15px;
            flex-wrap: wrap;
        }
        .radio-group, .agree-group {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 18px;
        }
        button {
            font-family:system-ui;
            font-weight: bold;
            background-color: #1c1201;
            color: white;
            border: none;
            padding:14px 32px;
            border-radius:8px;
            cursor:pointer;
            font-size:16px;
            margin-top: 20px;
        }

        /* 导航 */
        .navbar {
            width: 100%;
            height: 70px;
            background-color: rgba(87, 86, 86, 0.915);
            display: flex;
            align-items: center;
            position: fixed;top:0;
            z-index: 999;
            padding:0 50px;
        }
        .nav-registration {flex: 1;display:flex;align-items:center;gap:15px;}
        .nav-right {flex: none;display: flex;gap:30px;align-items: center;}
        .nav-item {text-align: center;padding: 0 10px;}
        .nav-registration a{color: burlywood;font-size: 24px;font-weight: bold;text-decoration: none;transition: all 0.3s ease;}
        .nav-item a {font-size:15px;color: white;font-weight: bold;text-decoration: none;transition: all 0.3s ease;padding:6px 12px;border-radius:4px;}
        .nav-registration a:hover, .nav-item a:hover {color:#35f361;background:rgba(255,255,0,0.1);}
        .box3{width:100%;height:60px;background-color: rgba(87, 86, 86, 0.915);position:fixed;bottom:0;color:white;font-size:15px;text-align:center;line-height:60px;z-index: 99;}
        body{margin: 0;padding-bottom:80px;padding-top:70px;}
        .logo {height: 50px;vertical-align: middle;}
        hr{display: none;}
    </style>
</head>
