<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Car Seller Registration Page</title>
    <style>
        *{margin:0;padding:0;box-sizing:border-box;}
        .hero-banner{
            width:100%;
            height: 800px;
            background-image: url("greencar.jpg");
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            position:relative;
            display:flex;flex-direction:column;justify-content:center;align-items:center;color:white;text-align:center;
        }
        .hero-banner::before{content:'';position:absolute;top:0;left:0;width:100%;height:100%;background-color:rgba(0, 0, 0, 0.466);z-index:1;}
        .hero-title{font-size:60px;font-weight:bold;position:relative;z-index:2;margin-bottom:16px;}
        .hero-desc{font-size:18px;position:relative;z-index:2;max-width:700px;line-height:1.6;}
        h1{color:#93db82;font-size: 38px;text-align:center;font-weight:bold;font-family:fantasy;margin:40px 0;text-shadow: 0 4px 12px rgba(0, 0, 0, 0.8);}
        h2{color:#222222;font-size: 28px;text-align:left;font-weight:bold;font-family:system-ui;margin-bottom:30px;}

        /* 灰色横条不动 */
        .gray-header-bar {
            width: 100%;
            background-color: #eaeaea;
            padding: 30px 0;
            font-size: 26px;
            font-weight: bold;
            color: #333;
            text-align: center;
            margin: 0 auto;
        }

        /* 左右两栏分散 */
        .form-card{
            max-width: 1400px;
            margin: 0 auto 80px;
            background: #ffffff;
            padding: 60px 80px;
            border-radius: 0 0 20px 20px;
            box-shadow: none;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 100px;
            position: relative;
            z-index: 10;
        }

        /* 左边靠左 完全不动 */
        .form-card form:nth-child(1) {
            justify-self: start;
            width:100%;
        }

        /* 右边整体靠右，内部全部左对齐！！你要的效果 */
        .form-card form:nth-child(2) {
            justify-self: end;
            text-align: left !important;
            width:fit-content;
        }

        /* ========== 重点！右侧内部 标题+输入框成对左右两列均分 ========== */
        .two-column-form {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            width:100%;
        }
        /* 每一组标题+输入框 单独占一行 */
        .form-item-group {
            display:flex;
            flex-direction:column;
            gap:10px;
            margin-bottom:25px;
        }

        .form-item-label{
            display:flex;
            align-items:center;
            gap:8px;
            width:160px;
            font-size: 22px;
            font-weight:600;
            color:#333333;
            margin:0;
            white-space: nowrap;
        }
        input{
            margin: 0;
            font-size:16px;
            padding:12px 16px;
            width:280px;
        }

        .radio-group, .agree-group{
            display:flex;
            align-items:center;
            gap:12px;
            font-size:18px;
            margin:12px 0;
            text-align:left;
        }

        .navbar {
            width: 100%;
            height: 70px;
            background-color: rgba(20,20,20,0.85);
            display: flex;
            align-items: center;
            position: fixed;top:0;
            z-index: 999;
            padding:0 50px;}
        .nav-registration {flex: 1;display:flex;align-items:center;gap:15px;}
        .nav-right {flex: none;display: flex;gap:30px;align-items: center;}
        .nav-item {text-align: center;padding: 0 10px;}
        .nav-registration a{color: burlywood;font-size: 24px;font-weight: bold;text-decoration: none;transition: all 0.3s ease;}
        .nav-item a {font-size:15px;color: white;font-weight: bold;text-decoration: none;transition: all 0.3s ease;padding:6px 12px;border-radius:4px;}
        .nav-registration a:hover, .nav-item a:hover {color:#35f361;background:rgba(255,255,0.1);}
        .box3{width:100%;height:60px;background-color: #333333;position:fixed;bottom:0;color:white;font-size:15px;text-align:center;line-height:60px;z-index: 99;}
        body{margin: 0;padding-bottom:80px;}

        button,input[type="submit"],input[type="button"] {
             font-family:system-ui;font-weight: bold;background-color: #1c1201;color: white;border: none;padding:14px 32px;border-radius:8px;cursor:pointer;font-size:16px;margin-top: 20px;
        }
        input[type="text"],input[type="password"],input[type="file"] {
            font-size:16px;background-color: #f8f8f8;border-radius:6px;height:48px;border:1px solid #eeeeee;outline:none;
        }
        input:focus{border-color:#666666;}
        button:hover,input[type="submit"]:hover,input[type="button"]:hover {background-color: #b89b6d;transform: translateY(-1px);box-shadow:none;}
        .logo {height: 50px;vertical-align: middle;}
        hr{display: none;}
    </style>

    <!-- 你原来所有JS函数！一个都没少！全部完整保留！ -->
    <script>
        function Username_True(){
            var username = document.getElementsByName("username")[0].value;
            if(username.length < 6){
                alert("The username must be more than five characters long.");
            }
        }
        function Password_True(){
            var password = document.getElementsByName("password")[0].value;
            if(password.length < 6){
                alert("The password must be more than five characters long.");
            }
        }
        function Verification(){
            alert("Verification code sent to your contact information!");
        }
        function Register(){
            var verification = document.getElementsByName("verification code")[0].value;
            if(verification!="1234"){
                alert("Incorrect verification code. Please try again.")
            }else{
                alert("Registration successful!");
            }
        }
        function Check() {
            var name = document.getElementById("FullName").value;
            var address = document.getElementById("Address").value;
            var phone = document.getElementById("Phone").value;
            var email = document.getElementById("Email").value;

            var nameReg = /^[a-zA-Z ]+$/;
            if (!nameReg.test(name)) {
                 alert("Name: letters only");
                 return false;
            }

            var addrReg = /^[a-zA-Z0-9 ]+$/;
            if (!addrReg.test(address)) {
                 alert("Address: alphanumeric only");
                 return false;
            }

            var phoneReg = /^1[3-9]\d{9}$/;
            if (!phoneReg.test(phone)) {
                 alert("Invalid China phone");
                 return false;
            }

            var emailReg = /^[^@]+@[^@]+\.(com|cn)$/;
             if (!emailReg.test(email)) {
                 alert("Email: one @, end with .com/.cn");
                 return false;
            }
             alert('Submit Successfully!');
             location.href='login.html';
             return true;
        }
    </script>
</head>
<body>

<div class="navbar">
    <div class="nav-registration">
        <img src="logo.jpg" class="logo">
        <a href="carregistration.html">REGISTRATION</a>
    </div>
    <div class="nav-right">
        <div class="nav-item"><a href="login.html">Login in</a></div>
        <div class="nav-item"><a href="add-car-page.html">Add car</a></div>
        <div class="nav-item"><a href="f1 homepage.html">Homepage</a></div>
    </div>
</div>

<div class="hero-banner">
    <h1 class="hero-title">Become A Certified Car Seller</h1>
    <p class="hero-desc">Complete simple registration steps to join our professional second-hand & new car sales service platform.</p>
</div>

<div class="gray-header-bar"></div>

<div class="form-card">
    <!-- 左侧 完全不动！！ -->
    <form>
        <h2>Registration Information</h2>
        <label class="form-item-label">Username:</label>
        <input type="text" name="username" placeholder="Your Username">
        <br>
        <label class="form-item-label">Password:</label>
        <input type="password" name="password" placeholder="Your Password">
        <br>
        <label class="form-item-label">Verification Code :</label>
        <div style="display:flex;gap:12px;align-items:center;">
            <input type="text" name="verification code" placeholder="Enter Verification Code" style="width:140px;">
            <button type="button" onclick="Verification()">Send Code</button>
        </div>
        <br>
        <button type="submit" onclick="Username_True();Password_True();Register();">Register</button>
        <br>
        <a href="login.html" style="font-size:16px;color:#333;margin-top:10px;">Already have an account?</a>
    </form>

    <!-- 右侧：标题+输入框 成对左右两列！！完美对应你参考图！！ -->
    <form>
        <h2>Personal Information</h2>
        <div class="two-column-form">
            <!-- 左侧第一列 -->
            <div class="form-item-group">
                <label class="form-item-label">Full Name:</label>
                <input type="text" id="FullName" placeholder="Your Full Name">
            </div>
            <div class="form-item-group">
                <label class="form-item-label">Address:</label>
                <input type="text" id="Address" placeholder="Your Address">
            </div>
            <div class="form-item-group">
                <label class="form-item-label">Phone:</label>
                <input type="text" id="Phone" placeholder="Your Phone Number">
            </div>

            <!-- 右侧第二列 -->
            <div class="form-item-group">
                <label class="form-item-label">ID Number:</label>
                <input type="password" name="id number" placeholder="ID Number">
            </div>
            <div class="form-item-group">
                <label class="form-item-label">ID Photo:</label>
                <input type="file" name="id photo"style="border-radius: 6px;height:48px;">
            </div>
            <div class="form-item-group">
                <label class="form-item-label">Email:</label>
                <input type="text" id="Email" placeholder="Your Email">
            </div>
        </div>

        <label class="form-item-label">Seller Type:</label>
        <div class="radio-group" style="gap:10px;">
            <input type="radio" name="seller type"> Individual
            <input type="radio" name="seller type"> Dealer
        </div>
        <br>

        <h2>Agreement</h2>
        <div class="agree-group">
            <input type="checkbox" name="agreement"style="gap:10px;">
            <span>I confirm all information is true.</span>
        </div>
        <br>

       <button type="button" onclick="Check();" style="font-size:18px;">Submit</button>
    </form>
</div>

<div class="box3">Any Problem? Contact Us!  3024579532@qq.com</div>
</body>
</html>
